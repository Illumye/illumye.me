---
import Navbar from '../components/Navbar.astro';
// On permet de changer le titre dynamiquement pour chaque page
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="fr">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body>
		<Navbar />
		<slot />
	</body>
</html>

<style is:global>
    /* Le "is:global" est la clé : il applique le style à tout le site */

	:root {
		background-color: #0d0d14;
	}
    html,
    body {
        margin: 0;
        width: 100%;
        min-height: 100%;
        background-color: #0d0d14; /* Enfin le fond sombre ! */
        color: #a9b1d6;
        font-family: 'Inter', system-ui, -apple-system, sans-serif;
    }

    /* On nettoie les styles par défaut des liens */
    a {
        text-decoration: none;
        color: inherit;
    }

    * {
        box-sizing: border-box;
    }
</style>
---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import ubgarden from "../assets/ubgarden.png";

const projects = [
  {
    title: "Net Puzzle Game",
    type: "Académique",
    status: "Terminé",
    tech: "C / SDL / Emscripten",
    desc: "Clone du jeu 'Net' de S. Tatham.  Disponible en terminal, GUI (SDL) et version web via Emscripten.",
    link: "https://angy-seguy.emi.u-bordeaux.fr/net-a22-zt94km/",
    label: "Jouer en ligne",
  },
  {
    title: "UBGarden",
    type: "Académique",
    status: "Terminé",
    tech: "Java",
    desc: "Jeu de gestion de jardin développé en Java avec une interface graphique.",
    image: ubgarden,
  },
  {
    title: "Fork UKit",
    type: "Perso",
    status: "Actif",
    tech: "JavaScript / TypeScript / React",
    desc: "Fork de UKit, une application compagnon pour les étudiants de l'Université de Bordeaux, développée en JavaScript avec React.",
    link: "https://ukit.illumye.me",
    label: "Voir le site",
  },
  {
    title: "Compilateur",
    type: "Académique",
    status: "En cours",
    tech: "OCaml",
    desc: "Développement d'un compilateur en OCaml dans le cadre d'un projet académique.",
  },
  {
    title: "Dev Logiciel (Nom à définir)",
    type: "Académique",
    status: "En cours",
    tech: "Java / Spring Boot / Vue.js",
    desc: "Projet de développement logiciel utilisant Java avec Spring Boot pour le backend et Vue.js pour le frontend, actuellement en cours de développement.",
  },
];

const statusAssets: Record<string, { color: string; icon: string }> = {
  Terminé: {
    color: "#9ece6a",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>`,
  },
  Actif: {
    color: "#7aa2f7",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>`,
  },
  "En cours": {
    color: "#e0af68",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v4m0 12v4M4.93 4.93l2.83 2.83m8.48 8.48l2.83 2.83M2 12h4m12 0h4M4.93 19.07l2.83-2.83m8.48-8.48l2.83-2.83"/></svg>`,
  },
};
---

<Layout title="Portfolio | illumye.me">
  <main>
    <h1>Mes travaux</h1>
    <div class="grid">
      {
        projects.map((p) => (
          <div class="card">
            <div class="header-padding">
              <div class="header">
                <span class="type">{p.type}</span>
                <span
                  class={`status-pill ${p.status === "En cours" ? "is-loading" : ""}`}
                  style={`--status-color: ${statusAssets[p.status as keyof typeof statusAssets]?.color || "#fff"}`}
                >
                  <Fragment
                    set:html={
                      statusAssets[p.status as keyof typeof statusAssets]?.icon
                    }
                  />
                  {p.status}
                </span>
              </div>
            </div>

            {p.image && (
              <Image
                src={p.image}
                alt={`Capture d'écran de ${p.title}`}
                class="project-img"
              />
            )}

            <div class="card-body">
              <h3>{p.title}</h3>
              <p class="tech">
                <code>{p.tech}</code>
              </p>
              <p class="desc">{p.desc}</p>
              {p.link && (
                <a href={p.link} target="_blank" class="btn">
                  {p.label}
                </a>
              )}
            </div>
          </div>
        ))
      }
    </div>
  </main>
</Layout>

<style>
  /* Mise en page globale */
  main {
    max-width: 1000px; /* Légèrement plus large pour plus de confort */
    margin: 60px auto;
    padding: 0 24px;
    color: #a9b1d6; /* Couleur de texte douce style Tokyo Night */
    font-family:
      system-ui,
      -apple-system,
      sans-serif;
  }

  h1 {
    font-size: 2.5rem;
    color: white;
    margin-bottom: 0.5rem;
  }

  /* Grille de projets */
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 30px;
    margin-top: 50px;
  }

  /* Style de la carte */
  .card {
    background: #16161e;
    border: 1px solid #23232e;
    border-radius: 14px;
    display: flex;
    flex-direction: column;
    height: 100%; /* Force toutes les cartes à avoir la même hauteur */
    overflow: hidden;
    transition: all 0.3s ease;
  }

  .card:hover {
    transform: translateY(-8px);
    border-color: #3b4261;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.4);
  }

  /* Header (Type et Statut) au dessus de l'image */
  .header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 20px 20px 15px 20px;
  }

  .status-pill {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 4px 10px;
    background: rgba(255, 255, 255, 0.03); /* Fond très léger */
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 6px;
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--status-color);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  /* On peut même ajouter une petite animation de rotation lente pour le "En cours" */
  .status-pill svg {
    flex-shrink: 0;
  }

  .status-pill.is-loading svg {
    animation: rotate 4s linear infinite;
    /* On ajoute un transform-origin pour être sûr que ça tourne bien sur son centre */
    transform-origin: center;
  }

  @keyframes rotate {
    from {
      transform: rotate(0deg);
    }
    to {
      transform: rotate(360deg);
    }
  }

  .type {
    color: #7aa2f7;
  }

  .status {
    color: #9ece6a;
  }

  .status.wait {
    color: #e0af68; /* Orange pour "En cours" */
  }

  /* Gestion de l'image */
  .project-img {
    width: 100%;
    height: 200px; /* Hauteur fixe pour ne pas écraser le texte */
    object-fit: cover; /* Recadre l'image proprement */
    border-top: 1px solid #23232e;
    border-bottom: 1px solid #23232e;
  }

  /* Conteneur de texte */
  .card-body {
    padding: 24px;
    display: flex;
    flex-direction: column;
    flex-grow: 1; /* Permet au texte de prendre l'espace restant */
  }

  h3 {
    margin: 0;
    font-size: 1.4rem;
    color: white;
  }

  .tech {
    margin: 10px 0;
    color: #bb9af7;
    font-size: 0.85rem;
  }

  .tech code {
    background: rgba(187, 154, 247, 0.1);
    padding: 4px 8px;
    border-radius: 4px;
  }

  .desc {
    font-size: 0.95rem;
    line-height: 1.6;
    color: #787c99;
    margin-bottom: 20px;
  }

  /* Bouton aligné en bas */
  .btn {
    margin-top: auto; /* Pousse le bouton tout en bas de la carte */
    display: inline-block;
    padding: 10px 20px;
    background: #3b4261;
    color: white;
    text-decoration: none;
    border-radius: 8px;
    font-size: 0.9rem;
    font-weight: 600;
    text-align: center;
    transition: background 0.2s;
    align-self: flex-start; /* Évite que le bouton prenne toute la largeur */
  }

  .btn:hover {
    background: #7aa2f7;
  }
</style>

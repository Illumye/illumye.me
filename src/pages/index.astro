---
// src/pages/index.astro
// Page de redirection automatique
---

<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Angy Seguy - Redirection...</title>
    <script>
      // Détection de la langue du navigateur
      const userLang = navigator.language || navigator.userLanguage;
      
      // Si la langue commence par "en" (en-US, en-GB, etc.), on redirige vers l'anglais
      if (userLang.toLowerCase().startsWith('en')) {
        window.location.replace('/en/');
      } else {
        // Sinon, on redirige vers le français par défaut
        window.location.replace('/fr/');
      }
    </script>
  </head>
  <body style="background-color: #0d0d14; color: #a9b1d6; font-family: sans-serif; display: flex; justify-content: center; align-items: center; height: 100vh; margin: 0;">
    <div style="text-align: center;">
      <p>Redirection en cours...</p>
      <a href="/fr/" style="color: #7aa2f7; text-decoration: none; margin: 0 10px;">Français</a> | 
      <a href="/en/" style="color: #7aa2f7; text-decoration: none; margin: 0 10px;">English</a>
    </div>
  </body>
</html>
---
import Layout from '../layouts/Layout.astro';

const navLinks = [
  {
    title: "Portfolio",
    description: "Mes projets académiques et personnels (C, Java, OCaml, JS).",
    url: "/portfolio",
    icon: "📁"
  },
  {
    title: "UKit",
    description: "Mon fork de l'application compagnon pour les étudiants de l'UB.",
    url: "https://ukit.illumye.me",
    icon: "🛠️",
    external: true
  },
  {
    title: "Le Labo",
    description: "Expérimentations, outils et trucs en cours.",
    url: "/lab",
    icon: "🧪"
  }
];
---

<Layout title="Hub | illumye.me">
	<main>
		<section class="hero">
			<div class="status-badge">🟢 Disponible pour des projets</div>
			<h1>Salut, moi c'est <span class="text-gradient">illumye</span></h1>
			<p class="subtitle">
				Étudiant en informatique passionné par le <strong>bas niveau</strong>, 
				le <strong>jeu vidéo</strong> et le <strong>développement web</strong> moderne.
			</p>
			
			<div class="social-links">
				<a href="https://github.com/Illumye" target="_blank" class="social-btn">GitHub</a>
				<a href="mailto:contact@illumye.me" class="social-btn">Email</a>
			</div>
		</section>

		<div class="grid-nav">
			{navLinks.map((link) => (
				<a href={link.url} target={link.external ? "_blank" : "_self"} class="nav-card">
					<div class="card-icon">{link.icon}</div>
					<div class="card-content">
						<h2>{link.title} {link.external && <span class="external-icon">↗</span>}</h2>
						<p>{link.description}</p>
					</div>
				</a>
			))}
		</div>

		<section class="current-work">
			<h3>🚀 En ce moment sur...</h3>
			<div class="status-item">
				<span class="emoji">⚙️</span>
				<p>Compilateur <strong>OCaml</strong> (Analyseur & Génération)</p>
			</div>
			<div class="status-item">
				<span class="emoji">🏗️</span>
				<p>Backend <strong>Spring Boot</strong> & Frontend <strong>Vue.js</strong></p>
			</div>
		</section>
	</main>
</Layout>

<style>
	/* On force le style pour que ça ne dépende plus du template */
	:global(body) {
		background-color: #0d0d14 !important; /* Fond très sombre */
		margin: 0;
		font-family: 'Inter', sans-serif;
	}

	main {
		max-width: 800px;
		margin: 0 auto;
		padding: 80px 24px;
		color: #a9b1d6;
	}

	.hero {
		text-align: center;
		margin-bottom: 4rem;
	}

	.status-badge {
		display: inline-block;
		padding: 5px 15px;
		background: rgba(158, 206, 106, 0.1);
		color: #9ece6a;
		border-radius: 20px;
		font-size: 0.85rem;
		font-weight: 600;
		border: 1px solid rgba(158, 206, 106, 0.2);
		margin-bottom: 2rem;
	}

	h1 {
		font-size: 4rem; /* Plus gros ! */
		font-weight: 800;
		color: white;
		margin: 0;
		line-height: 1.1;
	}

	.text-gradient {
		background: linear-gradient(45deg, #7aa2f7, #bb9af7);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-size: 400%;
	}

	.subtitle {
		font-size: 1.25rem;
		line-height: 1.6;
		margin-top: 20px;
		color: #787c99;
	}

	.social-links {
		margin-top: 30px;
		display: flex;
		justify-content: center;
		gap: 15px;
	}

	.social-btn {
		color: white;
		text-decoration: none;
		padding: 10px 24px;
		background: #1a1b26;
		border: 1px solid #24283b;
		border-radius: 8px;
		font-weight: 600;
		transition: 0.2s;
	}

	.social-btn:hover {
		border-color: #7aa2f7;
		background: #24283b;
	}

	.grid-nav {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
		gap: 20px;
	}

	.nav-card {
		background: #16161e;
		border: 1px solid #23232e;
		padding: 24px;
		border-radius: 12px;
		display: flex;
		gap: 20px;
		text-decoration: none;
		color: inherit;
		transition: 0.3s ease;
	}

	.nav-card:hover {
		transform: translateY(-5px);
		border-color: #7aa2f7;
	}

	.card-icon {
		font-size: 2.2rem;
	}

	h2 {
		margin: 0;
		font-size: 1.3rem;
		color: white;
	}

	.card-content p {
		margin: 8px 0 0 0;
		font-size: 0.95rem;
		line-height: 1.5;
	}

	.current-work {
		margin-top: 60px;
		padding: 30px;
		background: rgba(122, 162, 247, 0.05);
		border-radius: 12px;
		border: 1px solid #23232e;
	}

	.current-work h3 {
		color: white;
		margin-top: 0;
		font-size: 1.1rem;
		margin-bottom: 20px;
	}

	.status-item {
		display: flex;
		align-items: center;
		gap: 15px;
		margin-bottom: 12px;
	}

	.status-item p { margin: 0; }
</style>
---
import Layout from "../../layouts/Layout.astro";
import { Image } from "astro:assets";

// Import des images des projets
import ukit from "../../assets/app-screenshot.jpg";

// Import des assets du mini-jeu Net
import imgCorner from "../../assets/CORNER.png";
import imgCross from "../../assets/CROSS.png";
import imgEndpoint from "../../assets/ENDPOINT.png";
import imgSegment from "../../assets/SEGMENT.png";
import imgTee from "../../assets/TEE.png";

const projects = [
  {
    title: "Net Puzzle Game",
    tech: "C / SDL / Emscripten",
    desc: "Clone du jeu 'Net' de S. Tatham. Disponible en terminal, GUI (SDL) et version web via Emscripten.",
    link: "https://angy-seguy.emi.u-bordeaux.fr/net-a22-zt94km/",
    label: "Jouer en ligne",
    isInteractive: true,
  },
  {
    title: "Moteur de Recherche d'Images",
    tech: "Java / Spring Boot / Vue.js",
    desc: "Application client-serveur de recherche d'images par similarité. Backend avec base vectorielle (PostgreSQL/pgvector), indexation par descripteurs visuels, et interface client en TypeScript/Vue.js.",
  },
  {
    title: "Interpréteur Mini-ml",
    tech: "OCaml",
    desc: "Réalisation d'un interpréteur pour un sous-ensemble d'OCaml. Implémentation d'un parseur de syntaxe étendue et de typeurs gérant le polymorphisme faible et fort.",
  },
  {
    title: "UKit",
    tech: "JavaScript / TypeScript / React",
    desc: "Application compagnon pour les étudiants de l'Université de Bordeaux. Développée et maintenue en équipe au sein du KAE-Lab.",
    image: ukit,
    link: "https://ukit.illumye.me",
    label: "Voir le site",
  },
];
---

<Layout title="Angy Seguy">
  <main class="snap-container scrolly-main">
    <section class="snap-screen hero-section">
      <div class="hero-content">
        <h1 class="reveal delay-1">Angy<br />Seguy.</h1>
        <p class="subtitle reveal delay-2">
          Développeur passionné par le <span class="text-white">bas niveau</span
          >, l'<span class="text-white">ingénierie logicielle</span> et le <span
            class="text-white">web moderne</span
          >.
        </p>
        <div class="social-links reveal delay-3">
          <a
            href="https://github.com/Illumye"
            target="_blank"
            class="link-hover">GitHub</a
          >
          <a
            href="https://github.com/KAE-Lab/"
            target="_blank"
            class="link-hover">KAE-Lab</a
          >
          <a href="mailto:angy@kaelab.dev" class="link-hover">Email</a>
        </div>
      </div>
      <div class="scroll-indicator reveal delay-4">
        <span>Scroll</span>
        <div class="line"></div>
      </div>
    </section>

    <section id="en-cours" class="snap-screen content-section">
      <div class="content-wrapper">
        <h2 class="reveal section-title">Actuellement.</h2>
        <div class="work-statement reveal delay-1">
          <p>
            Je maintiens et développe <strong class="text-white">UKit</strong> au
            sein de l'équipe <strong class="text-white">KAE-Lab</strong>. En
            parallèle, je travaille sur un interpréteur <strong
              class="text-white">Mini-ml (OCaml)</strong
            > et une application full-stack de recherche d'images avec <strong
              class="text-white">Spring Boot</strong
            > et <strong class="text-white">Vue.js</strong>.
          </p>
        </div>
      </div>
    </section>

    {
      projects.map((p, index) => (
        <section
          id={index === 0 ? "projets" : `projet-${index}`}
          class="snap-screen content-section"
        >
          <div class="content-wrapper">
            {index === 0 && <h2 class="reveal section-title">Travaux.</h2>}

            <article class="project-item reveal delay-1">
              <div class="project-info">
                <span class="tech-stack">{p.tech}</span>
                <h3>{p.title}</h3>
                <p>{p.desc}</p>
                {p.link && (
                  <a href={p.link} target="_blank" class="project-link">
                    {p.label}
                  </a>
                )}
              </div>

              {/* --- MINI-JEU OU IMAGE --- */}
              {p.isInteractive ? (
                <div class="project-visual interactive-wrapper mario-style">
                  <p class="game-hint" id="net-hint">
                    Répare les tuyaux ↓
                  </p>
                  <div class="net-grid" id="net-grid">
                    <img
                      src={imgCorner.src}
                      class="net-cell"
                      data-rot="0"
                      alt="pipe"
                    />
                    <img
                      src={imgTee.src}
                      class="net-cell"
                      data-rot="90"
                      alt="pipe"
                    />
                    <img
                      src={imgCorner.src}
                      class="net-cell"
                      data-rot="270"
                      alt="pipe"
                    />

                    <img
                      src={imgTee.src}
                      class="net-cell"
                      data-rot="0"
                      alt="pipe"
                    />
                    <img
                      src={imgCross.src}
                      class="net-cell"
                      data-rot="90"
                      alt="pipe"
                    />
                    <img
                      src={imgTee.src}
                      class="net-cell"
                      data-rot="0"
                      alt="pipe"
                    />

                    <img
                      src={imgCorner.src}
                      class="net-cell"
                      data-rot="180"
                      alt="pipe"
                    />
                    <img
                      src={imgTee.src}
                      class="net-cell"
                      data-rot="270"
                      alt="pipe"
                    />
                    <img
                      src={imgCorner.src}
                      class="net-cell"
                      data-rot="90"
                      alt="pipe"
                    />
                  </div>
                </div>
              ) : (
                p.image && (
                  <div class="project-visual">
                    <Image src={p.image} alt={p.title} class="img-fluid" />
                  </div>
                )
              )}
            </article>
          </div>
        </section>
      ))
    }
    <section class="snap-screen footer-section">
      <div class="content-wrapper footer-content">
        <h2>Contact.</h2>
        <div class="footer-links">
          <a href="mailto:angy@kaelab.dev" class="link-hover">angy@kaelab.dev</a
          >
          <a
            href="https://github.com/Illumye"
            target="_blank"
            class="link-hover">GitHub</a
          >
          <a
            href="https://linkedin.com/in/angy-seguy-2573042b2"
            target="_blank"
            class="link-hover">LinkedIn</a
          >
        </div>
        <div class="footer-bottom">
          <p class="copyright">© {new Date().getFullYear()} Angy Seguy.</p>
          <a href="#" class="back-to-top" title="Remonter en haut">
            Haut
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"><path d="m18 15-6-6-6 6"></path></svg
            >
          </a>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style is:global>
  /* --- CONFIGURATION DU SCROLL SNAPPING --- */
  html {
    scroll-snap-type: y mandatory;
    overflow-y: scroll;
  }

  .snap-screen {
    height: 100vh;
    width: 100%;
    scroll-snap-align: start;
    scroll-snap-stop: always;
    display: flex;
    flex-direction: column;
    justify-content: center;
    position: relative;
  }

  /* --- STYLES DE BASE --- */
  .scrolly-main {
    color: #d1d1d1;
  }

  .content-wrapper,
  .hero-content {
    padding: 0 5vw;
    max-width: 1200px;
    width: 100%;
    margin: 0 auto;
  }

  /* --- ANIMATIONS SCROLLYTELLING --- */
  .reveal {
    opacity: 0;
    transform: translateY(40px);
    transition:
      opacity 1s cubic-bezier(0.16, 1, 0.3, 1),
      transform 1s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .reveal.active {
    opacity: 1;
    transform: translateY(0);
  }

  .delay-1 {
    transition-delay: 0.1s;
  }
  .delay-2 {
    transition-delay: 0.3s;
  }
  .delay-3 {
    transition-delay: 0.5s;
  }
  .delay-4 {
    transition-delay: 0.8s;
  }

  /* --- TYPOGRAPHIE GLOBALE --- */
  .scrolly-main h1,
  .scrolly-main h2,
  .scrolly-main h3 {
    color: #ffffff;
    font-weight: 500;
    letter-spacing: -0.04em;
    margin: 0;
  }

  .text-white {
    color: #ffffff;
    font-weight: 500;
  }

  /* --- HERO SECTION --- */
  .hero-section h1 {
    font-size: clamp(4rem, 10vw, 8rem);
    line-height: 0.95;
    margin-bottom: 2rem;
  }

  .hero-section .subtitle {
    font-size: clamp(1.2rem, 2.5vw, 1.8rem);
    line-height: 1.4;
    color: #888;
    max-width: 800px;
  }

  .social-links {
    margin-top: 3rem;
    display: flex;
    gap: 2rem;
  }

  .link-hover {
    font-size: 1.1rem;
    color: #fff !important;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    position: relative;
    padding-bottom: 4px;
    text-decoration: none;
  }

  .link-hover::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 1px;
    background: #fff;
    transition: width 0.3s ease;
  }

  .link-hover:hover::after {
    width: 100%;
  }

  .scroll-indicator {
    position: absolute;
    bottom: 40px;
    left: 5vw;
    display: flex;
    align-items: center;
    gap: 1rem;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #666;
  }

  .scroll-indicator .line {
    width: 60px;
    height: 1px;
    background: #666;
  }

  /* --- TITRES DE SECTIONS --- */
  .section-title {
    font-size: clamp(2rem, 4vw, 3rem);
    margin-bottom: 3rem;
    border-bottom: 1px solid #222;
    padding-bottom: 1rem;
  }

  /* --- EN COURS --- */
  .work-statement p {
    font-size: clamp(1.5rem, 3vw, 2.5rem);
    line-height: 1.3;
    color: #888;
    max-width: 900px;
  }

  /* --- PROJETS --- */
  .project-item {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    align-items: center;
  }

  @media (min-width: 768px) {
    .project-item {
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
    }
  }

  .tech-stack {
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #666;
    display: block;
    margin-bottom: 1rem;
  }

  .project-info h3 {
    font-size: clamp(1.8rem, 3vw, 2.5rem);
    margin-bottom: 1rem;
  }

  .project-info p {
    font-size: 1.1rem;
    line-height: 1.6;
    color: #888;
    margin-bottom: 2rem;
  }

  .project-link {
    display: inline-block;
    padding: 12px 24px;
    border: 1px solid #333;
    border-radius: 30px;
    color: #fff !important;
    font-size: 0.9rem;
    text-decoration: none;
    transition: all 0.3s;
  }

  .project-link:hover {
    background: #fff;
    color: #000 !important;
  }

  .project-visual {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
  }

  .img-fluid {
    /* --- Taille pour Téléphone --- */
    max-width: 90%;
    max-height: 280px;
    width: auto;
    height: auto;
    object-fit: contain;
    display: block;
    filter: grayscale(20%);
    border-radius: 5px;
    transition:
      transform 0.7s ease,
      filter 0.7s ease;
  }

  /* --- Taille pour Ordinateur (écrans > 768px) --- */
  @media (min-width: 768px) {
    .img-fluid {
      max-width: 100%; /* L'image peut prendre toute la largeur de sa colonne */
      max-height: 550px; /* On augmente la hauteur max sans prendre tout l'écran */
    }
  }

  .project-item:hover .img-fluid {
    transform: scale(1.05);
    filter: grayscale(0%);
  }

  /* --- MINI-JEU NET PUZZLE AVEC ASSETS --- */
  .interactive-wrapper.mario-style {
    background: linear-gradient(to bottom, #5c94fc 0%, #8ab1ff 100%);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    border-radius: 8px;
    box-shadow: inset 0 0 20px rgba(0, 0, 0, 0.1);
  }

  .interactive-wrapper.mario-style .game-hint {
    font-family: monospace;
    font-size: 0.85rem;
    color: #fff;
    background: rgba(0, 0, 0, 0.4);
    padding: 6px 12px;
    border-radius: 4px;
    margin-bottom: 1.5rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    animation: pulseText 2s infinite;
  }

  /* --- STYLES DE VICTOIRE DU MINI-JEU --- */
  .interactive-wrapper.mario-style .game-hint.win-state {
    background: rgba(20, 20, 25, 0.8);
    border: 1px solid #9ece6a;
    color: #9ece6a;
    animation: none;
    transition: all 0.3s ease;
  }

  .interactive-wrapper.mario-style .game-hint.win-state a {
    color: #fff;
    text-decoration: underline;
    margin-left: 8px;
    font-weight: bold;
  }

  .interactive-wrapper.mario-style .game-hint.win-state a:hover {
    color: #9ece6a;
  }

  @keyframes pulseText {
    0%,
    100% {
      opacity: 0.7;
    }
    50% {
      opacity: 1;
    }
  }

  .net-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    width: 200px;
    height: 200px;
    filter: drop-shadow(0 10px 15px rgba(0, 0, 0, 0.3));
  }

  .net-cell {
    width: 100%;
    height: 100%;
    object-fit: cover;
    cursor: pointer;
    image-rendering: pixelated;
    transition:
      transform 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275),
      filter 0.2s;
  }

  .net-cell:hover {
    filter: brightness(1.2);
    z-index: 10;
  }

  /* --- FOOTER --- */
  .footer-section {
    background-color: #0d0d14; /* S'assure que rien ne passe au travers */
    position: relative;
    z-index: 10;
  }

  .footer-content {
    display: flex;
    flex-direction: column;
    height: 100%;
    padding-top: 100px; /* Décale le contenu pour éviter la Navbar */
  }

  .footer-content h2 {
    font-size: clamp(3rem, 6vw, 5rem);
    margin-bottom: 2rem;
    border: none;
    padding: 0;
    color: #fff;
  }

  .footer-links {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    font-size: 1.2rem;
    margin-bottom: auto; /* Pousse le copyright tout en bas */
    align-items: flex-start;
  }

  /* --- FOOTER BOTTOM (Copyright & Retour en haut) --- */
  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
    margin-top: auto; /* Pousse ce bloc tout en bas */
    padding-bottom: 2rem;
  }

  .copyright {
    font-size: 0.85rem;
    color: #565f89; /* Le gris bleuté */
    margin: 0;
  }

  .back-to-top {
    display: flex;
    align-items: center;
    gap: 6px;
    color: #7aa2f7;
    font-size: 0.9rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .back-to-top svg {
    transition: transform 0.3s ease;
  }

  .back-to-top:hover {
    color: #fff;
  }

  .back-to-top:hover svg {
    transform: translateY(
      -4px
    ); /* Fait sautiller la flèche vers le haut au survol */
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    // 1. Logique du Scrollytelling
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("active");
          } else {
            entry.target.classList.remove("active");
          }
        });
      },
      { threshold: 0.3 },
    );

    document.querySelectorAll(".reveal").forEach((el) => {
      observer.observe(el);
    });

    // 2. Logique du Mini-Jeu Net
    const cells = document.querySelectorAll(".net-cell");
    const hint = document.getElementById("net-hint");
    const grid = document.getElementById("net-grid");
    let isWon = false;

    // Solution : rotations requises pour chaque case (la croix au centre, index 4, est ignorée)
    const winningState = [90, 180, 180, 90, 0, 270, 0, 0, 270];

    function checkWin() {
      let win = true;
      cells.forEach((cell, index) => {
        if (index === 4) return; // On ignore la croix

        // Astuce mathématique pour gérer les modulos négatifs dus aux clics droits (-90° = 270°)
        const rawRot = parseInt(cell.getAttribute("data-rot"));
        const rot = ((rawRot % 360) + 360) % 360;

        if (rot !== winningState[index]) win = false;
      });

      if (win && !isWon) {
        isWon = true;
        hint.innerHTML =
          'Tu as gagné ! <a href="https://angy-seguy.emi.u-bordeaux.fr/net-a22-zt94km/" target="_blank">Jouer au vrai jeu -></a>';
        hint.classList.add("win-state");

        grid.style.transition = "filter 0.5s ease";
        grid.style.filter = "drop-shadow(0 0 25px rgba(158, 206, 106, 0.8))";

        cells.forEach((c) => {
          c.style.cursor = "default";
          c.style.pointerEvents = "none";
        });
      }
    }

    cells.forEach((cell) => {
      // Initialiser la rotation de départ
      const rot = parseInt(cell.getAttribute("data-rot") || "0");
      cell.style.transform = `rotate(${rot}deg)`;

      // --- CLIC GAUCHE : Tourne dans le sens horaire (+90°) ---
      cell.addEventListener("click", function (e) {
        if (isWon) return;
        let currentRot = parseInt(this.getAttribute("data-rot") || "0");
        currentRot += 90;

        this.setAttribute("data-rot", currentRot);
        this.style.transform = `rotate(${currentRot}deg)`;
        checkWin();
      });

      // --- CLIC DROIT : Tourne dans le sens anti-horaire (-90°) ---
      cell.addEventListener("contextmenu", function (e) {
        e.preventDefault(); // Empêche l'ouverture du menu contextuel du navigateur
        if (isWon) return;

        let currentRot = parseInt(this.getAttribute("data-rot") || "0");
        currentRot -= 90;

        this.setAttribute("data-rot", currentRot);
        this.style.transform = `rotate(${currentRot}deg)`;
        checkWin();
      });
    });
  });
</script>
